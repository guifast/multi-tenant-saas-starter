{
  "name": "@saas/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --dir test --passWithNoTests",
    "test:e2e": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@nestjs/common": "11.1.9",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "11.1.9",
    "@nestjs/platform-express": "11.1.9",
    "@nestjs/swagger": "11.2.3",
    "@nestjs/throttler": "6.5.0",
    "@saas/config": "workspace:*",
    "@saas/contracts": "workspace:*",
    "@saas/database": "workspace:*",
    "bcryptjs": "3.0.3",
    "cookie-parser": "1.4.7",
    "helmet": "8.1.0",
    "nanoid": "5.1.6",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.12",
    "@nestjs/testing": "11.1.9",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/node": "26.0.1",
    "@types/supertest": "6.0.3",
    "supertest": "7.1.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
