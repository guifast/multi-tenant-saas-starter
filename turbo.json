{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@saas/api#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@saas/web#build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "env": [
        "DATABASE_URL",
        "SESSION_SECRET",
        "API_PORT",
        "WEB_PORT",
        "WEB_ORIGIN",
        "NEXT_PUBLIC_API_URL"
      ],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URL", "TEST_DATABASE_URL", "SESSION_SECRET", "WEB_ORIGIN"],
      "cache": false
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URL", "TEST_DATABASE_URL", "SESSION_SECRET", "WEB_ORIGIN"],
      "cache": false
    }
  }
}
